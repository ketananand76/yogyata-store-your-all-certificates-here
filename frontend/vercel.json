{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://sanchay-store-your-all-certificates-here.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://sanchay-store-your-all-certificates-here.onrender.com/uploads/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://sanchay-store-your-all-certificates-here.onrender.com/socket.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

